<% wday = %w[日 月 火 水 木 金 土] %>

<div class="index-header">
  <h1>予約カレンダー</h1>
  <%= link_to "🎤 新しく予約する", new_reservation_path, class: "btn" %>
</div>
<%= month_calendar(events: @reservations, attribute: :date, end_attribute: :date) do |date, reservations| %>
  <div class="calendar-day">
    <div class="date-number"><%= date.day %></div>
    <% if reservations.any? %>
      <%= link_to reservations_path(date: date.iso8601, anchor: "day-panel"),
                  class: "day-link#{' is-selected' if @selected_date == date}" do %>
        <% reservations.each do |reservation| %>
          <span class="reservation-entry <%= reservation_status_class(reservation) %>"><%= reservation.start_time.strftime('%H:%M') %> <%= reservation.facility_label %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>

<div id="day-panel" class="day-panel">
  <% if @selected_date %>
    <div class="section-title">
      <span class="dot"></span>
      <%= @selected_date.strftime("%Y年%-m月%-d日") %>（<%= wday[@selected_date.wday] %>）の予約状況
    </div>

    <% if @day_reservations.any? %>
      <div class="reservation-list">
        <% @day_reservations.each do |reservation| %>
          <div class="ticket-card <%= reservation_status_class(reservation) %>">
            <div class="ticket-main">
              <div class="ticket-date">
                <%= reservation.start_time.strftime("%H:%M") %> 〜 <%= reservation.end_time.strftime("%H:%M") %>
                <% if owner_or_admin?(reservation) %>
                  <span class="mine-badge"><%= current_user.admin? ? "管理" : "自分の予約" %></span>
                <% end %>
                <% if current_user.admin? && reservation.recently_created? && !reservation.prepared? %>
                  <span class="new-badge">NEW</span>
                <% end %>
              </div>
              <div class="ticket-meta">
                <% if owner_or_admin?(reservation) %>
                  <%= reservation.room_number %>号室
                  ・<%= reservation.name %>
                  <% if current_user.admin? %>・📞 <%= reservation.phone.presence || "未登録" %><% end %>
                  ・大人<%= reservation.adult_count %>/子供<%= reservation.child_count %>
                <% else %>
                  予約済み
                <% end %>
              </div>
              <% if current_user.admin? %>
                <div class="ticket-admin">
                  <% if reservation.prepared? %>
                    <span class="status-tag done">✓ <%= reservation.prepared_label %></span>
                    <%= button_to "取り消し", unprepare_reservation_path(reservation), method: :patch, class: "mini-btn" %>
                  <% else %>
                    <%= button_to reservation.prepare_action_label, prepare_reservation_path(reservation), method: :patch, class: "mini-btn primary" %>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div style="display: flex; align-items: center; gap: 12px;">
              <span class="ticket-badge"><%= reservation.facility_label %></span>
              <% if owner_or_admin?(reservation) %>
                <div class="ticket-actions">
                  <%= link_to "詳細", reservation %>
                  <%= link_to "編集", edit_reservation_path(reservation) %>
                  <%= link_to "削除", reservation, data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか?" }, class: "danger" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>この日の予約はありません。</p>
    <% end %>

    <%= link_to "× 選択を解除", reservations_path, class: "link-back" %>
  <% else %>
    <div class="day-panel-hint">
      📅 カレンダーの<strong>予約済みの日</strong>をクリックすると、その日の予約状況がここに表示されます。
    </div>
  <% end %>
</div>
