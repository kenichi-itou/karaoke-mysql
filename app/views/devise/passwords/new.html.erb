<div class="section-title"><span class="dot"></span>パスワードの再設定</div>

<div class="auth-card">
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <% if resource.errors.any? %>
      <div class="flash-error-box">
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field-group">
      <div class="field-label">📧 メールアドレス</div>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "例: taro@example.com", required: true %>
      <div class="field-hint">※ 登録済みのメールアドレスに、パスワード再設定用のリンクをお送りします。</div>
    </div>

    <div>
      <%= f.submit "再設定メールを送信", class: "btn" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
