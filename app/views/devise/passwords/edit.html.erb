<div class="section-title"><span class="dot"></span>新しいパスワードの設定</div>

<div class="auth-card">
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <% if resource.errors.any? %>
      <div class="flash-error-box">
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :reset_password_token %>

    <div class="field-group">
      <div class="field-label">🔑 新しいパスワード<% if @minimum_password_length %>（<%= @minimum_password_length %>文字以上）<% end %></div>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "新しいパスワード", required: true %>
    </div>

    <div class="field-group">
      <div class="field-label">🔑 新しいパスワード（確認）</div>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "もう一度入力", required: true %>
    </div>

    <div>
      <%= f.submit "パスワードを変更", class: "btn" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
