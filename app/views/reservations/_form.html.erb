<%= form_with(model: reservation) do |form| %>
  <% if reservation.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(reservation.errors.count, "error") %> prohibited this reservation from being saved:</h2>

      <ul>
        <% reservation.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :date %>
    <%= form.date_field :date %>
  </div>

  <div>
    <%= form.label :start_time %>
    <%= form.time_field :start_time %>
  </div>

  <div>
    <%= form.label :end_time %>
    <%= form.time_field :end_time %>
  </div>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :room_number %>
    <%= form.text_field :room_number %>
  </div>

  <div>
    <%= form.label :phone %>
    <%= form.text_field :phone %>
  </div>

  <div>
    <%= form.label :facility %>
    # <%= form.text_field :facility %>
    <%= form.select :facility, [["カラオケ","karaoke"], ["バーベキュー","bbq"]] %>
  </div>

  <div>
    <%= form.label :adult_count %>
    <%= form.number_field :adult_count %>
  </div>

  <div>
    <%= form.label :child_count %>
    <%= form.number_field :child_count %>
  </div>

  <div>
    <%= form.submit %>
  </div>

<% end %>