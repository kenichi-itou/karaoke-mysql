<% if notice.present? %>
  <div class="flash-notice"><%= notice %></div>
<% end %>

<div class="section-title"><span class="dot"></span>予約詳細</div>

<div class="receipt">
  <div class="receipt-top">
    <div class="brand">🎤 共用施設 予約チケット</div>
    <div class="hero-tagline"><%= @reservation.date.strftime("%Y年%-m月%-d日") %>（<%= %w[日 月 火 水 木 金 土][@reservation.date.wday] %>）</div>
  </div>

  <div class="receipt-body">
    <div class="receipt-row">
      <span class="label">🕒 時間</span>
      <span class="value"><%= @reservation.start_time.strftime("%H:%M") %> 〜 <%= @reservation.end_time.strftime("%H:%M") %></span>
    </div>
    <div class="receipt-row">
      <span class="label">🎶 利用設備</span>
      <span class="value"><%= @reservation.facility_label %></span>
    </div>

    <% if owner_or_admin?(@reservation) %>
      <div class="receipt-row">
        <span class="label">🚪 部屋番号</span>
        <span class="value"><%= @reservation.room_number %></span>
      </div>
      <div class="receipt-row">
        <span class="label">👤 予約者名</span>
        <span class="value"><%= @reservation.name %></span>
      </div>
      <div class="receipt-row">
        <span class="label">📞 電話番号</span>
        <span class="value"><%= @reservation.phone %></span>
      </div>
      <div class="receipt-row">
        <span class="label">🧑‍🤝‍🧑 人数</span>
        <span class="value">大人 <%= @reservation.adult_count %>名 ・ 子供 <%= @reservation.child_count %>名</span>
      </div>
    <% else %>
      <div class="receipt-row">
        <span class="label">状態</span>
        <span class="value">予約済み</span>
      </div>
      <div class="receipt-note">この時間帯は予約済みです。予約者の個人情報は本人と管理人のみ閲覧できます。</div>
    <% end %>
  </div>

  <div class="receipt-total">
    <div class="receipt-total-line">
      <span class="label">💰 使用料</span>
      <span class="amount"><%= number_with_delimiter(@reservation.fee) %>円</span>
    </div>
    <div class="receipt-fee-note">
      <% if @reservation.facility == "karaoke" %>
        <% h = @reservation.duration_hours %>
        カラオケルーム 100円/時間 × <%= (h % 1).zero? ? h.to_i : h %>時間
      <% else %>
        バーベキューコーナー 100円/回
      <% end %>
    </div>
  </div>

  <% if owner_or_admin?(@reservation) %>
    <div class="receipt-actions">
      <%= link_to "この予約を編集", edit_reservation_path(@reservation), class: "btn" %>
      <%= button_to "予約を削除", @reservation, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "この予約を削除しますか？" } } %>
    </div>
  <% end %>
</div>

<%= link_to "← 予約一覧に戻る", reservations_path, class: "link-back" %>
