<!DOCTYPE html>
<html>
  <head>
    <title>共用施設予約 | マンション共用施設予約システム</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="hero">
      <div class="hero-inner">
        <div>
          <div class="brand">🎤 共用施設予約</div>
          <div class="hero-tagline">マンション共用施設予約システム</div>
        </div>
        <nav class="hero-nav">
          <% if user_signed_in? %>
            <%= link_to "予約一覧・カレンダー", reservations_path %>
            <%= link_to "新規予約", new_reservation_path %>
            <% if current_user.admin? %>
              <%= link_to "使用料集計", usage_reports_path %>
            <% end %>
            <span class="hero-user">
              <%= current_user.name.presence || current_user.email %>
              <% if current_user.admin? %><span class="role-tag">管理人</span><% end %>
            </span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "hero-nav-btn" %>
          <% else %>
            <%= link_to "ログイン", new_user_session_path %>
            <%= link_to "新規登録", new_user_registration_path %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="page">
      <% if notice %>
        <p class="flash-notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="flash-alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>